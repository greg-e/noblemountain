# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# MongoDB connection string (required)
# Local development example:
#   MONGODB_URI=mongodb://localhost:27017/realtimelandscape
# Atlas example:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/realtimelandscape?retryWrites=true&w=majority
MONGODB_URI=

# HTTP port the API server listens on (default: 3001)
PORT=3001
