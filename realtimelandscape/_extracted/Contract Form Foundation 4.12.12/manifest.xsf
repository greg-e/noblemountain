		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechOctMH" expression="xdMath:Nz(../my:TechOctFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechNovMH" expression="xdMath:Nz(../my:TechNovFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechDecMH" expression="xdMath:Nz(../my:TechDecFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GeneralAnnualPrice" expression="round(sum(xdMath:Nz(../../my:PricingTable/my:AnnualPrice)) + xdMath:Nz(../../my:GeneralVisitCalculations/my:GeneralTravelPrice))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GeneralAnnualLaborCost" expression="sum(xdMath:Nz(../../my:PricingTable/my:LaborAnnualCost)) + xdMath:Nz(../../my:GeneralVisitCalculations/my:GeneralTravelCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GeneralAnnualMaterialCost" expression="sum(xdMath:Nz(../../my:PricingTable/my:MaterialAnnualCost))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GeneralCostTotal" expression="xdMath:Nz(../my:GeneralAnnualLaborCost) + xdMath:Nz(../my:GeneralAnnualMaterialCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:TechnicalAnnualPrice" expression="round(sum(xdMath:Nz(../../my:TechnicalPricingTable/my:TechAnnualPrice)))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:TechnicalAnnualLaborCost" expression="sum(xdMath:Nz(../../my:TechnicalPricingTable/my:TechLaborAnnualCost))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:TechnicalAnnualMaterialCost" expression="sum(xdMath:Nz(../../my:TechnicalPricingTable/my:TechMaterialAnnualCost))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:TechnicalCostTotal" expression="xdMath:Nz(../my:TechnicalAnnualLaborCost) + xdMath:Nz(../my:TechnicalAnnualMaterialCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:ContractPrice" expression="round(xdMath:Nz(../my:GeneralAnnualPrice) + xdMath:Nz(../my:TechnicalAnnualPrice))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:ContractCost" expression="xdMath:Nz(../my:GeneralCostTotal) + xdMath:Nz(../my:TechnicalCostTotal)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GrossProfit" expression="xdMath:Nz(../my:ContractPrice) - xdMath:Nz(../my:ContractCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:ContractTotals/my:GrossProfitPercent" expression="xdMath:Nz(../my:GrossProfit) div xdMath:Nz(../my:ContractPrice)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralTravelCost" expression="xdMath:Nz(../my:GeneralMonthlyTravel/my:TotalMonthlyTravel) * xdMath:Nz(../../my:GeneralLaborCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralTravelPrice" expression="xdMath:Nz(../my:GeneralMonthlyTravel/my:TotalMonthlyTravel) * (xdMath:Nz(../../my:GeneralLaborCost) + xdMath:Nz(../../my:GeneralOverheadAndProfit))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMonthlyTravel/my:JanMTravel" expression="xdMath:Nz(../../my:GeneralTravel/my:JanTravel) * xdMath:Nz(../../my:GeneralSiteVisits/my:JanVisits)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMonthlyTravel/my:FebMTravel" expression="xdMath:Nz(../../my:GeneralTravel/my:FebTravel) * xdMath:Nz(../../my:GeneralSiteVisits/my:FebVisits)" refresh="onChange"></xsf:calculatedField>
