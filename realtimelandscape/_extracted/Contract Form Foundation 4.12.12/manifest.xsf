		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMonthlyTravel/my:DecMTravel" expression="xdMath:Nz(../../my:GeneralTravel/my:DecTravel) * xdMath:Nz(../../my:GeneralSiteVisits/my:DecVisits)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMonthlyTravel/my:TotalMonthlyTravel" expression="xdMath:Nz(../my:JanMTravel) + xdMath:Nz(../my:FebMTravel) + xdMath:Nz(../my:MarMTravel) + xdMath:Nz(../my:AprMTravel) + xdMath:Nz(../my:MayMTravel) + xdMath:Nz(../my:JunMTravel) + xdMath:Nz(../my:JulMTravel) + xdMath:Nz(../my:AugMTravel) + xdMath:Nz(../my:SepMTravel) + xdMath:Nz(../my:OctMTravel) + xdMath:Nz(../my:NovMTravel) + xdMath:Nz(../my:DecMTravel)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:ProjectDisplayName" expression="xdXDocument:GetDOM(&quot;Projects&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Title[../d:ID = xdXDocument:get-DOM()/my:myFields/my:ProjectName]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:PricingTable/my:UnitMultiplier" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Unit_x0020_Multiplier[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechUnitMultiplier" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Unit_x0020_Multiplier[../d:ID = current()/../my:TechActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffAreaTotal" expression="../../my:TakeOffDetail/my:GeneralArea/my:AreaActivityTotal[current()/../my:TakeOffActivity = ../my:GeneralAreaActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffLinearTotal" expression="../../my:TakeOffDetail/my:GeneralLinear/my:LinearActivityTotal[current()/../my:TakeOffActivity = ../my:GeneralLinearActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffActivityTotal" expression="xdMath:Nz(../my:TakeOffAreaTotal) + xdMath:Nz(../my:TakeOffLinearTotal) + xdMath:Nz(../my:TakeOffCountTotal) + xdMath:Nz(../my:TakeOffVolumeTotal)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffCountTotal" expression="../../my:TakeOffDetail/my:GeneralCount/my:CountActivityTotal[current()/../my:TakeOffActivity = ../my:GeneralCountActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffVolumeTotal" expression="../../my:TakeOffDetail/my:GeneralVolume/my:VolumeActivityTotal[current()/../my:TakeOffActivity = ../my:GeneralVolumeActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffActivityMultiplier" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Unit_x0020_Multiplier[../d:ID = current()/../my:RelatedActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TakeOff/my:TakeOffEntry/my:TakeOffActivityUnit" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Unit[../d:ID = current()/../my:RelatedActivity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:JanPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:JanMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:JanVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:FebPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:FebMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:FebVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:MarPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:MarMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:MarVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:AprPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:AprMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:AprVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:MayPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:MayMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:MayVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:JunPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:JunMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:JunVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:JulPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:JulMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:JulVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:AugPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:AugMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:AugVisits))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMHOnSitePerVisit/my:SepPV" expression="ceiling(xdMath:Nz(../../my:GeneralMHSum/my:SepMHSum) div xdMath:Nz(../../my:GeneralSiteVisits/my:SepVisits))" refresh="onChange"></xsf:calculatedField>
