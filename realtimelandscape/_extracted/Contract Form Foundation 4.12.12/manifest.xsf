	<xsf:domEventHandlers></xsf:domEventHandlers>
	<xsf:ruleSets>
		<xsf:ruleSet name="ruleSet_7">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:switchViewAction view="Contract Services"></xsf:switchViewAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_17">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:switchViewAction view="Contract Total"></xsf:switchViewAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_18">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:switchViewAction view="Contract Services"></xsf:switchViewAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_23">
			<xsf:rule caption="QueryID" isEnabled="yes">
				<xsf:queryAction adapter="Retrieve IDs"></xsf:queryAction>
			</xsf:rule>
			<xsf:rule caption="Set Next ID" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) &gt; 0 and my:strFilename = &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="xdMath:Max(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) + 1"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Set Initial ID to 1" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) = 0" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="&quot;1&quot;"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Edit" condition="my:strFilename != &quot;&quot;" isEnabled="yes">
				<xsf:submitAction adapter="SharePoint Library Submit"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
			<xsf:rule caption="Submit" condition="my:strFilename = &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:strFilename" expression="concat(my:ProjectDisplayName, &quot; - &quot;, &quot;Contract &quot;, my:numID)"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:ContractID" expression="my:numID"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:CreatedDate" expression="xdDate:Today()"></xsf:assignmentAction>
				<xsf:submitAction adapter="SharePoint Library Submit"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_25">
			<xsf:rule caption="Rule 2" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:strFilename" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:ProjectName" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:ContractID" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:ShowActivities" expression="&quot;Yes&quot;"></xsf:assignmentAction>
				<xsf:queryAction adapter="Pricing Table"></xsf:queryAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_26">
			<xsf:rule caption="QueryID" isEnabled="yes">
				<xsf:queryAction adapter="Retrieve IDs"></xsf:queryAction>
			</xsf:rule>
			<xsf:rule caption="Set Next ID" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) &gt; 0 and my:strFilename = &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="xdMath:Max(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) + 1"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Set Initial ID to 1" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) = 0" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="&quot;1&quot;"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Edit" condition="my:strFilename != &quot;&quot;" isEnabled="yes">
				<xsf:submitAction adapter="SharePoint Library Submit"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
