		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechAnnualPrice" expression="xdMath:Nz(../my:TechUnitPrice) * xdMath:Nz(../my:TechQuantity) * xdMath:Nz(../my:TechTotalFreq)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechJanMH" expression="xdMath:Nz(../my:TechJanFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechFebMH" expression="xdMath:Nz(../my:TechFebFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechMarMH" expression="xdMath:Nz(../my:TechMarFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechAprMH" expression="xdMath:Nz(../my:TechAprFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechMayMH" expression="xdMath:Nz(../my:TechMayFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechJunMH" expression="xdMath:Nz(../my:TechJunFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechJulMH" expression="xdMath:Nz(../my:TechJulFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:TechnicalPricingTable/my:TechAugMH" expression="xdMath:Nz(../my:TechAugFreq) * (xdMath:Nz(../my:TechMH) + xdMath:Nz(../my:TechTravelPerVisit) * xdMath:Nz(../my:TechCrewSize))" refresh="onChange"></xsf:calculatedField>
