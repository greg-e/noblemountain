		<xsf:calculatedField target="/my:myFields/my:EstimateGroup/my:GeneralVisitCalculations/my:GeneralMonthlyTravel/my:JunMTravel" expression="xdMath:Nz(../../my:GeneralTravel/my:JunTravel) * xdMath:Nz(../../my:GeneralSiteVisits/my:JunVisits)" refresh="onChange"></xsf:calculatedField>
