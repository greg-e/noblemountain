			<xsf:query>
				<xsf:sharepointListAdapterRW queryAllowed="yes" submitAllowed="no" siteURL="../" sharePointListID="{1292F3E9-EA58-4CB8-B853-5C3F828D9F80}" name="Pricing Table" contentTypeID="" sortBy="Title" sortAscending="yes" relativeListUrl="../Lists/Pricing%20Table/">
					<xsf:field internalName="Title" required="yes" type="Text"></xsf:field>
					<xsf:field internalName="Activity_x0020_Category" required="no" type="Choice"></xsf:field>
					<xsf:field internalName="Unit" required="no" type="Text"></xsf:field>
					<xsf:field internalName="Unit_x0020_Multiplier" required="no" type="Number"></xsf:field>
					<xsf:field internalName="Unit_x0020_Category" required="no" type="Choice"></xsf:field>
					<xsf:field internalName="Production_x0020_Rate" required="no" type="Number"></xsf:field>
					<xsf:field internalName="Material_x0020_Rate" required="no" type="Number"></xsf:field>
					<xsf:field internalName="Description" required="no" type="Text"></xsf:field>
