			<xsf:field name="Crew Size" columnName="{2E3A8A89-7FE7-4088-9C23-BF0604CA947B}" node="/my:myFields/my:CrewSize" type="xsd:double"></xsf:field>
			<xsf:field name="Total Visits" columnName="{8A5A1AE4-B99B-4ABB-AE24-6FF11054F5DC}" node="/my:myFields/my:TotalVisits" type="xsd:double"></xsf:field>
			<xsf:field name="Total Workorder Price" columnName="{DD666835-08CF-45F6-9148-1DE36901A739}" node="/my:myFields/my:TotalWorkorderPrice" type="xsd:double"></xsf:field>
			<xsf:field name="Total Workorder Cost" columnName="{3F5D31B4-191C-4F52-B872-50E93CFD82D3}" node="/my:myFields/my:TotalWorkorderCost" type="xsd:double"></xsf:field>
			<xsf:field name="Workorder Description" columnName="{F94E109D-B38B-429B-8C9D-E351FB0AB95E}" node="/my:myFields/my:WorkorderDescription" type="xsd:string"></xsf:field>
