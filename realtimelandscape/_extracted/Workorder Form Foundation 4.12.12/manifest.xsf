	<xsf:calculations>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:Description" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Description[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:Unit" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Unit[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:ManHoursPerUnit" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Production_x0020_Rate[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:MaterialCostPerUnit" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Material_x0020_Rate[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:LaborPricePerManHour" expression="xdMath:Nz(../my:LaborCostPerManHour) + xdMath:Nz(../my:OverheadAndProfitPerManHour)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalLaborHours" expression="xdMath:Nz(../my:Quantity) * xdMath:Nz(../my:ManHoursPerUnit)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalMaterialCost" expression="(xdMath:Nz(../my:MaterialCostPerUnit) + xdMath:Nz(../my:ManualMaterialCostPerUnit)) * xdMath:Nz(../my:Quantity)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalLaborCost" expression="xdMath:Nz(../my:TotalLaborHours) * xdMath:Nz(../my:LaborCostPerManHour)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalLaborPrice" expression="xdMath:Nz(../my:LaborPricePerManHour) * xdMath:Nz(../my:TotalLaborHours)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:MaterialMarkup" expression="(xdMath:Nz(../my:MaterialCostPerUnit) + xdMath:Nz(../my:ManualMaterialCostPerUnit)) * xdMath:Nz(../my:MaterialMarkupPercent)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:WarrantyMarkup" expression="(xdMath:Nz(../my:MaterialCostPerUnit) + xdMath:Nz(../my:ManualMaterialCostPerUnit)) * xdMath:Nz(../my:LiveMaterialWarrantyPercent)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalMaterialPrice" expression="(xdMath:Nz(../my:MaterialMarkup) + xdMath:Nz(../my:WarrantyMarkup) + xdMath:Nz(../my:MaterialCostPerUnit) + xdMath:Nz(../my:ManualMaterialCostPerUnit)) * xdMath:Nz(../my:Quantity)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:PricePerUnit" expression="(xdMath:Nz(../my:TotalMaterialPrice) + xdMath:Nz(../my:TotalLaborPrice)) div xdMath:Nz(../my:Quantity)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:TotalPrice" expression="xdMath:Nz(../my:TotalMaterialPrice) + xdMath:Nz(../my:TotalLaborPrice)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:RoundTrip" expression="xdXDocument:GetDOM(&quot;Projects&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Round_x0020_Trip[../d:ID = xdXDocument:get-DOM()/my:myFields/my:Project]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalManHours" expression="sum(xdMath:Nz(../my:PricingTable/my:TotalLaborHours))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:AverageHourlyRate" expression="xdMath:Avg(../my:PricingTable/my:LaborPricePerManHour)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PriceSubtotal" expression="sum(xdMath:Nz(../my:PricingTable/my:TotalPrice))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalVisits" expression="(xdMath:Nz(../my:TotalManHours) div xdMath:Nz(../my:WorkDayHours)) div xdMath:Nz(../my:CrewSize)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalTravelHours" expression="(xdMath:Nz(../my:RoundTrip) * xdMath:Nz(../my:TotalVisits)) * xdMath:Nz(../my:CrewSize)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TravelPrice" expression="xdMath:Nz(../my:TotalTravelHours) * xdMath:Nz(../my:AverageHourlyRate)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalWorkorderPrice" expression="round(xdMath:Nz(../my:PriceSubtotal) + xdMath:Nz(../my:TravelPrice))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalWorkorderCost" expression="sum(xdMath:Nz(../my:PricingTable/my:TotalLaborCost)) + sum(xdMath:Nz(../my:PricingTable/my:TotalMaterialCost)) + (xdMath:Nz(../my:TotalTravelHours) * xdMath:Avg(../my:PricingTable/my:LaborCostPerManHour))" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalWorkorderProfit" expression="xdMath:Nz(../my:TotalWorkorderPrice) - xdMath:Nz(../my:TotalWorkorderCost)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PercentProfit" expression="xdMath:Nz(../my:TotalWorkorderProfit) div xdMath:Nz(../my:TotalWorkorderPrice)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:OnsiteCrewHours" expression="xdMath:Nz(../my:TotalManHours) div xdMath:Nz(../my:CrewSize)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:TotalVisitsRoundedUp" expression="ceiling(../my:TotalVisits)" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:ProjectDisplayName" expression="xdXDocument:GetDOM(&quot;Projects&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Title[../d:ID = xdXDocument:get-DOM()/my:myFields/my:Project]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:ProjectID" expression="xdXDocument:GetDOM(&quot;Projects&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID[. = xdXDocument:get-DOM()/my:myFields/my:Project]" refresh="onChange"></xsf:calculatedField>
		<xsf:calculatedField target="/my:myFields/my:PricingTable/my:ActivityDisplayName" expression="xdXDocument:GetDOM(&quot;Pricing Table&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:Title[../d:ID = current()/../my:Activity]" refresh="onChange"></xsf:calculatedField>
	</xsf:calculations>
	<xsf:submit caption="Submit" disableMenuItem="no" onAfterSubmit="close" showStatusDialog="no">
		<xsf:errorMessage>The form cannot be submitted because of an error.</xsf:errorMessage>
		<xsf:davAdapter name="SharePoint Library Submit" submitAllowed="yes" overwriteAllowed="yes">
			<xsf:folderURL value="../workorder%20Library/"></xsf:folderURL>
			<xsf:fileName value="my:strFilename" valueType="expression"></xsf:fileName>
		</xsf:davAdapter>
	</xsf:submit>
	<xsf:ruleSets>
		<xsf:ruleSet name="ruleSet_1">
			<xsf:rule caption="QueryID" isEnabled="yes">
				<xsf:queryAction adapter="Retrieve IDs"></xsf:queryAction>
			</xsf:rule>
			<xsf:rule caption="Set Next ID" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) &gt; 0 and my:strFilename = &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="xdMath:Max(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) + 1"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Set Initial ID to 1" condition="count(xdXDocument:GetDOM(&quot;Retrieve IDs&quot;)/dfs:myFields/dfs:dataFields/d:SharePointListItem_RW/d:ID) = 0" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="&quot;1&quot;"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Edit" condition="my:strFilename != &quot;&quot;" isEnabled="yes">
				<xsf:submitAction adapter="SharePoint Library Submit"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
			<xsf:rule caption="Submit" condition="my:strFilename = &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:strFilename" expression="concat(my:ProjectDisplayName, &quot; - &quot;, &quot;Workorder&quot;, &quot; &quot;, my:numID)"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:WorkorderID" expression="my:numID"></xsf:assignmentAction>
				<xsf:submitAction adapter="SharePoint Library Submit"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_2">
			<xsf:rule caption="Rule 1" condition=". = string(true())" isEnabled="yes">
				<xsf:assignmentAction targetField="../my:TotalWorkorderPrice" expression="&quot;0&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="../my:TotalWorkorderProfit" expression="&quot;0&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="../my:PercentProfit" expression="&quot;0&quot;"></xsf:assignmentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_3">
			<xsf:rule caption="Rule 1" condition="my:IncludedWork = string(true())" isEnabled="yes">
				<xsf:assignmentAction targetField="my:TotalWorkorderPrice" expression="&quot;0&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:TotalWorkorderProfit" expression="&quot;0&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:PercentProfit" expression="&quot;0&quot;"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Rule 2" condition="my:WorkorderID = &quot;&quot;" isEnabled="yes">
				<xsf:queryAction adapter="Pricing Table"></xsf:queryAction>
				<xsf:assignmentAction targetField="my:ShowActivities" expression="&quot;Yes&quot;"></xsf:assignmentAction>
			</xsf:rule>
			<xsf:rule caption="Rule 3" condition="my:WorkorderID != &quot;&quot;" isEnabled="yes">
				<xsf:assignmentAction targetField="my:ShowActivities" expression="&quot;No&quot;"></xsf:assignmentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_4">
			<xsf:rule caption="Rule 2" isEnabled="yes">
				<xsf:assignmentAction targetField="my:numID" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:strFilename" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:WorkorderID" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:Project" expression="&quot;&quot;"></xsf:assignmentAction>
				<xsf:assignmentAction targetField="my:ShowActivities" expression="&quot;Yes&quot;"></xsf:assignmentAction>
				<xsf:queryAction adapter="Pricing Table"></xsf:queryAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_5">
			<xsf:rule caption="Rule 2" isEnabled="yes">
				<xsf:submitAction adapter="Save Form"></xsf:submitAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_6">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:submitAction adapter="Save Form"></xsf:submitAction>
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_7">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:closeDocumentAction promptToSaveChanges="no"></xsf:closeDocumentAction>
			</xsf:rule>
		</xsf:ruleSet>
		<xsf:ruleSet name="ruleSet_8">
			<xsf:rule caption="Rule 1" isEnabled="yes">
				<xsf:queryAction adapter="Pricing Table"></xsf:queryAction>
			</xsf:rule>
			<xsf:rule caption="Rule 2" isEnabled="yes">
				<xsf:assignmentAction targetField="my:ShowActivities" expression="&quot;Yes&quot;"></xsf:assignmentAction>
			</xsf:rule>
		</xsf:ruleSet>
	</xsf:ruleSets>
	<xsf:domEventHandlers>
		<xsf:domEventHandler match="/my:myFields/my:IncludedWork">
